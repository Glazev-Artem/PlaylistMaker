<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/mainBackgroundColor"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/padding_16"
    android:paddingBottom="@dimen/padding_28">

    <TextView
        style="@style/HeaderTextStyle"
        android:layout_width="match_parent"
        android:layout_marginTop="@dimen/margin_14"
        android:layout_marginBottom="@dimen/margin_24"
        android:text="@string/header_main"
        android:textColor="?attr/mainHeaderTextColor" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_search"
        style="@style/MainButtonStyle"
        android:text="@string/button_search"
        app:icon="@drawable/ic_search_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_library"
        style="@style/MainButtonStyle"
        android:text="@string/button_library"
        app:icon="@drawable/ic_library_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_settings"
        style="@style/MainButtonStyle"
        android:text="@string/button_settings"
        app:icon="@drawable/ic_settings_24" />

</LinearLayout>
